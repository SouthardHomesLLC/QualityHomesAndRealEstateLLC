---
import Layout from '@layouts/Layout.astro';
import ListingCard from '@components/ListingCard.astro';
import { homesForSale } from '@data/ForSale';
---

<Layout>
    <main class="relative z-10 min-h-screen">
        <section class="mx-auto max-w-7xl px-6 pb-12 pt-20 text-center sm:pt-28">
            <h1
                class="text-4xl font-extrabold tracking-tight text-neutral-200 sm:text-5xl md:text-6xl"
            >
                Find Your <span class="text-gold-deep">Home</span>
            </h1>

            <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-neutral-400 sm:text-lg">
                Explore available homes throughout Terre Haute and the surrounding
                Wabash Valley.
            </p>

            <div
                class="mx-auto mt-8 h-px w-96 bg-linear-to-r from-transparent via-gold to-transparent"
            >
            </div>
        </section>

        <section class="mx-auto max-w-7xl px-6 pb-24">
            {
                homesForSale.length > 0 ? (
                    <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-3">
                        {
                            homesForSale.map((home) => (
                                <ListingCard
                                    listing={home}
                                    hrefPrefix="/homes-for-sale"
                                />
                            ))
                        }
                    </div>
                ) : (
                    <div class="mx-auto max-w-2xl rounded-2xl border border-neutral-800 bg-brand-darker/50 px-6 py-16 text-center">
                        <h2 class="text-2xl font-bold text-neutral-100">
                            New listings are coming soon
                        </h2>

                        <p class="mt-3 text-neutral-400">
                            Check back soon to explore homes available throughout the
                            Wabash Valley.
                        </p>
                    </div>
                )
            }
        </section>
    </main>
</Layout>