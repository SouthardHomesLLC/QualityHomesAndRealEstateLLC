---
// src/components/ListingCard.astro

import { Image } from 'astro:assets';

import type {
    ForSaleInfo,
    ListingStatus,
    RentalInfo
} from '@data/HomeInfo';

interface Props {
    listing: ForSaleInfo | RentalInfo;
    hrefPrefix: '/homes-for-sale' | '/rentals';
}

const { listing, hrefPrefix } = Astro.props;

const primaryImage =
    listing.images.find((image) => image.featured) ??
    listing.images[0];

const formatPrice = (price: number) =>
    new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 0
    }).format(price);

const statusDotStyles: Record<ListingStatus, string> = {
    available: 'bg-emerald-400',
    pending: 'bg-amber-400',
    sold: 'bg-gold',
    rented: 'bg-blue-400',
    unavailable: 'bg-neutral-500'
};

const formatStatus = (status: ListingStatus) =>
    status.charAt(0).toUpperCase() + status.slice(1);

const isRental = 'monthlyRent' in listing;

const price = isRental
    ? `${formatPrice(listing.monthlyRent)}/mo`
    : formatPrice(listing.purchasePrice);
---

<article
    class="group overflow-hidden rounded-2xl border-2 border-neutral-800
        bg-brand-darker/60 shadow-xl transition duration-300
        hover:-translate-y-1 hover:border-gold/60"
>
    <a
        href={`${hrefPrefix}/${listing.slug}`}
        aria-label={`View ${listing.address}`}
        class="block"
    >
        <div class="relative aspect-16/10 overflow-hidden bg-neutral-900">
            {
                primaryImage ? (
                    <Image
                        src={primaryImage.src}
                        alt={primaryImage.alt}
                        widths={[480, 640, 800]}
                        sizes="(min-width: 1280px) 33vw, (min-width: 768px) 50vw, 100vw"
                        format="webp"
                        quality={85}
                        loading="lazy"
                        class="h-full w-full object-cover"
                    />
                ) : (
                    <div
                        class="flex h-full items-center justify-center
                            text-sm text-neutral-500"
                    >
                        Photo coming soon
                    </div>
                )
            }

            <div
                class="absolute inset-0 bg-linear-to-t
                    from-black/70 via-transparent to-transparent"
            >
            </div>

            <span
                class="absolute right-4 top-4 flex items-center gap-2 rounded-full
                    border border-neutral-700 bg-brand-darker/95 px-3 py-1.5
                    text-xs font-semibold text-neutral-200 shadow-lg backdrop-blur-sm"
            >
                <span
                    class:list={[
                        'h-2 w-2 rounded-full',
                        statusDotStyles[listing.status]
                    ]}
                    aria-hidden="true"
                >
                </span>

                {formatStatus(listing.status)}
            </span>

            <p class="absolute bottom-2 left-4 text-2xl font-bold text-white">
                {price}
            </p>
        </div>

        <div class="p-4">
            <h2
                class="text-xl font-bold text-neutral-100 transition-colors
                    group-hover:text-gold"
            >
                {listing.address}
            </h2>

            <p class="mt-1 text-sm text-neutral-400">
                {listing.city}, {listing.state} {listing.zipCode}
            </p>

            <div
                class="my-5 grid grid-cols-3 divide-x divide-neutral-800
                    border-y border-neutral-800 py-4 text-center"
            >
                <div>
                    <strong class="block text-neutral-100">
                        {listing.bedrooms}
                    </strong>

                    <span class="text-xs text-neutral-500">
                        Beds
                    </span>
                </div>

                <div>
                    <strong class="block text-neutral-100">
                        {listing.bathrooms}
                    </strong>

                    <span class="text-xs text-neutral-500">
                        Baths
                    </span>
                </div>

                <div>
                    <strong class="block text-neutral-100">
                        {listing.squareFeet.toLocaleString()}
                    </strong>

                    <span class="text-xs text-neutral-500">
                        Sq. Ft.
                    </span>
                </div>
            </div>

            {
                listing.description && (
                    <p
                        class="line-clamp-3 text-sm leading-relaxed
                            text-neutral-400"
                    >
                        {listing.description}
                    </p>
                )
            }
            <div class="mt-4 flex items-center justify-center">
                <span 
                    class="rounded-full border border-gold/20 bg-gold/10 px-4 py-1.5
                    text-xs font-semibold text-gold transition-colors duration-300
                    group-hover:border-gold/40"
                >
                    View Property
                </span>
            </div>
        </div>
    </a>
</article>