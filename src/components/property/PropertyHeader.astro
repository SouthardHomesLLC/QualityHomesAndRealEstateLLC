---
import type { ForSaleInfo, ListingStatus } from '@data/HomeInfo';

interface Props { home: ForSaleInfo; }
const { home } = Astro.props;

const formatPrice = (price: number) => new Intl.NumberFormat('en-US', {
    style: 'currency', currency: 'USD', maximumFractionDigits: 0
}).format(price);

const statusDotStyles: Record<ListingStatus, string> = {
    available: 'bg-emerald-400', pending: 'bg-amber-400', sold: 'bg-gold',
    rented: 'bg-blue-400', unavailable: 'bg-neutral-500'
};

const formatStatus = (status: ListingStatus) =>
    status.charAt(0).toUpperCase() + status.slice(1);
---

<header class="mb-8 flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
    <div>
        <div class="mb-3 flex flex-wrap items-center gap-3">
            <span class="flex items-center gap-2 rounded-full border border-neutral-700 bg-brand-darker/95 px-3 py-1.5 text-xs font-semibold text-neutral-200">
                <span class:list={['h-2 w-2 rounded-full', statusDotStyles[home.status]]} aria-hidden="true"></span>
                {formatStatus(home.status)}
            </span>
            {home.mlsNumber && <span class="text-xs text-neutral-500">MLS #{home.mlsNumber}</span>}
        </div>
        <h1 class="text-3xl font-extrabold tracking-tight text-neutral-100 sm:text-4xl lg:text-5xl">
            {home.address}
        </h1>
        <p class="mt-2 text-base text-neutral-400 sm:text-lg">
            {home.city}, {home.state} {home.zipCode}
        </p>
    </div>
    <p class="text-3xl font-bold text-gold sm:text-4xl">{formatPrice(home.purchasePrice)}</p>
</header>

