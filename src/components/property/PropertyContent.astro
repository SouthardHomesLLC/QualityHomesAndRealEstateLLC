---
import type { ForSaleInfo, RentalInfo } from "@data/HomeInfo";
interface Props {
  home: ForSaleInfo | RentalInfo;
}
const { home } = Astro.props;
---

{
  home.description && (
    <section>
      <h2 class="text-2xl font-bold text-neutral-100">About This Home</h2>
      <div class="mt-3 h-px w-48 bg-linear-to-r from-gold to-transparent" />
      <p class="mt-5 max-w-3xl whitespace-pre-line leading-7 text-neutral-400">
        {home.description}
      </p>
    </section>
  )
}

{
  home.features && home.features.length > 0 && (
    <section>
      <h2 class="text-2xl font-bold text-neutral-100">Property Features</h2>
      <div class="mt-3 h-px w-48 bg-linear-to-r from-gold to-transparent" />
      <ul class="mt-6 grid gap-3 sm:grid-cols-2">
        {home.features.map((feature) => (
          <li class="flex items-start gap-3 rounded-xl border border-neutral-800 bg-brand-darker/40 p-4 text-sm text-neutral-300">
            <span
              class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-gold"
              aria-hidden="true"
            />
            {feature}
          </li>
        ))}
      </ul>
    </section>
  )
}
