---
import type { ForSaleInfo } from '@data/HomeInfo';
interface Props { home: ForSaleInfo; }
const { home } = Astro.props;
const facts = [
    [home.bedrooms, 'Bedrooms'],
    [home.bathrooms, 'Bathrooms'],
    [home.squareFeet.toLocaleString(), 'Square Feet'],
    [home.garageSpaces ?? '—', 'Garage Spaces']
];
---

<section 
    class="grid grid-cols-2 divide-x divide-y 
        divide-neutral-800 overflow-hidden rounded-2xl 
        border border-neutral-800 bg-brand-darker/60 
        sm:grid-cols-4 sm:divide-y-0"
>
    {facts.map(([value, label]) => (
        <div class="p-5 text-center">
            <strong class="block text-2xl text-neutral-100">{value}</strong>
            <span class="mt-1 block text-xs text-neutral-500">{label}</span>
        </div>
    ))}
</section>

