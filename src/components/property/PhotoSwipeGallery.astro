---
import { Image } from "astro:assets";
import type { PropertyImage } from "@data/HomeInfo";
import "photoswipe/style.css";

interface Props {
  images: PropertyImage[];
  galleryId: string;
  mode?: "preview" | "full";
  galleryUrl?: string;
}

const { images, galleryId, mode = "full", galleryUrl } = Astro.props;
const primary = images.find((image) => image.featured) ?? images[0];
const orderedImages = primary
  ? [primary, ...images.filter((image) => image !== primary)]
  : [];
const previewImages = orderedImages.slice(0, 3);
const renderedImages = mode === "preview" ? previewImages : orderedImages;
---

{
  renderedImages.length > 0 ? (
    <section
      id={galleryId}
      data-pswp-gallery
      aria-label="Property photos"
      class:list={[
        mode === "preview"
          ? "grid overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-900 lg:grid-cols-[minmax(0,1.7fr)_minmax(230px,0.7fr)] lg:gap-1"
          : "grid gap-4 sm:grid-cols-2 lg:grid-cols-3",
      ]}
    >
      {mode === "preview" ? (
        <>
          <a
            href={renderedImages[0].src.src}
            data-pswp-width={renderedImages[0].src.width}
            data-pswp-height={renderedImages[0].src.height}
            target="_blank"
            class="block aspect-16/10 overflow-hidden lg:aspect-auto lg:min-h-115"
          >
            <Image
              src={renderedImages[0].src}
              alt={renderedImages[0].alt}
              widths={[640, 960, 1280]}
              sizes="(min-width: 1024px) 70vw, 100vw"
              format="webp"
              quality={90}
              class="h-full w-full object-cover transition duration-300 hover:brightness-110"
            />
          </a>

          {renderedImages.length > 1 && (
            <div
              class:list={[
                "hidden gap-1 lg:grid",
                renderedImages.length > 2 ? "grid-rows-2" : "grid-rows-1",
              ]}
            >
              {renderedImages.slice(1, 3).map((image, index) => (
                <a
                  href={image.src.src}
                  data-pswp-width={image.src.width}
                  data-pswp-height={image.src.height}
                  target="_blank"
                  class="relative min-h-0 overflow-hidden"
                >
                  <Image
                    src={image.src}
                    alt={image.alt}
                    widths={[320, 480, 640]}
                    sizes="30vw"
                    format="webp"
                    quality={85}
                    loading="lazy"
                    class="h-full w-full object-cover transition duration-300 hover:brightness-110"
                  />
                  {index === 1 && images.length > 3 && (
                    <span class="absolute inset-0 flex items-center justify-center bg-black/55 text-sm font-semibold text-white">
                      +{images.length - 3} more photos
                    </span>
                  )}
                </a>
              ))}
            </div>
          )}

          {galleryUrl && (
            <a
              href={galleryUrl}
              class="absolute bottom-4 right-4 z-10 rounded-full border border-white/20 bg-black/80 px-4 py-2 text-sm font-semibold text-white shadow-lg backdrop-blur-sm transition hover:border-gold/50 hover:text-gold"
            >
              View all {images.length} photos
            </a>
          )}
        </>
      ) : (
        renderedImages.map((image, index) => (
          <a
            href={image.src.src}
            data-pswp-width={image.src.width}
            data-pswp-height={image.src.height}
            target="_blank"
            class:list={[
              "group block overflow-hidden rounded-xl border border-neutral-800 bg-neutral-900",
              index === 0 ? "sm:col-span-2 lg:col-span-2" : "",
            ]}
          >
            <Image
              src={image.src}
              alt={image.alt}
              widths={[480, 720, 1080]}
              sizes={
                index === 0
                  ? "(min-width: 1024px) 66vw, 100vw"
                  : "(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
              }
              format="webp"
              quality={88}
              loading={index === 0 ? "eager" : "lazy"}
              class:list={[
                "w-full object-cover transition duration-300 group-hover:scale-[1.02] group-hover:brightness-110",
                index === 0 ? "aspect-16/9" : "aspect-4/3",
              ]}
            />
          </a>
        ))
      )}
    </section>
  ) : (
    <section class="flex aspect-16/7 items-center justify-center rounded-2xl border border-neutral-800 bg-neutral-900 text-neutral-500">
      Property photos coming soon
    </section>
  )
}

<script>
  import PhotoSwipeLightbox from "photoswipe/lightbox";

  document
    .querySelectorAll<HTMLElement>("[data-pswp-gallery]")
    .forEach((gallery) => {
      const lightbox = new PhotoSwipeLightbox({
        gallery,
        children: "a[data-pswp-width]",
        pswpModule: () => import("photoswipe"),
      });

      lightbox.init();
    });
</script>

<style>
  [data-pswp-gallery] {
    position: relative;
  }
</style>
