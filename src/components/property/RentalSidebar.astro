---
import type { RentalInfo } from "@data/HomeInfo";

interface Props {
  rental: RentalInfo;
}

const { rental } = Astro.props;

const hasResources =
  rental.floorplan2DPath ||
  rental.floorplan3DPath ||
  rental.videoTourUrl ||
  rental.listingUrl;

const formatPrice = (price: number) =>
  new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: 0,
  }).format(price);

const formattedAvailableDate = rental.availableDate
  ? new Intl.DateTimeFormat("en-US", {
      month: "long",
      day: "numeric",
      year: "numeric",
    }).format(new Date(`${rental.availableDate}T00:00:00`))
  : undefined;
---

<aside>
  <div
    class="rounded-2xl border border-neutral-800
            bg-brand-darker/70 p-6 shadow-xl
            lg:sticky lg:top-24"
  >
    <p
      class="text-xs font-bold uppercase
                tracking-[0.2em] text-gold"
    >
      Interested in this rental?
    </p>

    <h2 class="mt-3 text-2xl font-bold text-neutral-100">
      Apply or schedule a tour
    </h2>

    <p class="mt-3 text-sm leading-6 text-neutral-400">
      Contact Quality Homes and Real Estate LLC to learn more about availability
      or arrange a private tour.
    </p>

    {
      rental.applicationUrl ? (
        <a
          href={rental.applicationUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-6 block rounded-full bg-gold px-5 py-3
                        text-center text-sm font-bold text-brand-darker
                        transition hover:bg-gold-deep"
        >
          Apply Now
          <span class="sr-only"> (opens in a new tab)</span>
        </a>
      ) : (
        <a
          href="/contact"
          class="mt-6 block rounded-full bg-gold px-5 py-3
                        text-center text-sm font-bold text-brand-darker
                        transition hover:bg-gold-deep"
        >
          Contact Us
        </a>
      )
    }

    {
      rental.applicationUrl && (
        <a
          href="/contact"
          class="mt-3 block text-center text-sm font-semibold
                        text-neutral-400 transition-colors hover:text-gold"
        >
          Schedule a tour
        </a>
      )
    }

    <dl class="mt-6 space-y-3 border-t border-neutral-800 pt-6">
      {
        rental.securityDeposit !== undefined && (
          <div class="flex justify-between gap-4 text-sm">
            <dt class="text-neutral-500">Security deposit</dt>

            <dd class="font-medium text-neutral-200">
              {formatPrice(rental.securityDeposit)}
            </dd>
          </div>
        )
      }

      {
        formattedAvailableDate && (
          <div class="flex justify-between gap-4 text-sm">
            <dt class="text-neutral-500">Available</dt>

            <dd class="text-right font-medium text-neutral-200">
              {formattedAvailableDate}
            </dd>
          </div>
        )
      }

      {
        rental.leaseTermMonths !== undefined && (
          <div class="flex justify-between gap-4 text-sm">
            <dt class="text-neutral-500">Lease term</dt>

            <dd class="font-medium text-neutral-200">
              {rental.leaseTermMonths} months
            </dd>
          </div>
        )
      }

      {
        rental.petsAllowed !== undefined && (
          <div class="flex justify-between gap-4 text-sm">
            <dt class="text-neutral-500">Pets</dt>

            <dd class="font-medium text-neutral-200">
              {rental.petsAllowed ? "Allowed" : "Not allowed"}
            </dd>
          </div>
        )
      }
    </dl>

    {
      hasResources && (
        <div
          class="mt-6 space-y-3 border-t
                        border-neutral-800 pt-6 text-sm"
        >
          <h3 class="font-semibold text-neutral-200">Additional Resources</h3>

          {rental.floorplan2DPath && (
            <a
              class="block text-gold hover:text-gold-deep"
              href={rental.floorplan2DPath}
              target="_blank"
              rel="noopener noreferrer"
            >
              View 2D floor plan
            </a>
          )}

          {rental.floorplan3DPath && (
            <a
              class="block text-gold hover:text-gold-deep"
              href={rental.floorplan3DPath}
              target="_blank"
              rel="noopener noreferrer"
            >
              View 3D floor plan
            </a>
          )}

          {rental.videoTourUrl && (
            <a
              class="block text-gold hover:text-gold-deep"
              href={rental.videoTourUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              Watch video tour
            </a>
          )}

          {rental.listingUrl && (
            <a
              class="block text-neutral-400 hover:text-gold"
              href={rental.listingUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              View original listing
              <span class="sr-only"> (opens in a new tab)</span>
            </a>
          )}
        </div>
      )
    }
  </div>
</aside>
