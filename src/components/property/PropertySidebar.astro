---
import type { ForSaleInfo } from "@data/HomeInfo";
interface Props {
  home: ForSaleInfo;
}
const { home } = Astro.props;
const hasResources =
  home.floorplan2DPath ||
  home.floorplan3DPath ||
  home.videoTourUrl ||
  home.listingUrl;
---

<aside>
  <div
    class="rounded-2xl border border-neutral-800 bg-brand-darker/70 p-6 shadow-xl lg:sticky lg:top-24"
  >
    <p class="text-xs font-bold uppercase tracking-[0.2em] text-gold">
      Interested in this home?
    </p>
    <h2 class="mt-3 text-2xl font-bold text-neutral-100">Schedule a showing</h2>
    <p class="mt-3 text-sm leading-6 text-neutral-400">
      Contact Quality Homes and Real Estate LLC to learn more or arrange a
      private tour.
    </p>
    <a
      href="/contact"
      class="mt-6 block rounded-full bg-gold px-5 py-3 text-center text-sm font-bold text-brand-darker transition hover:bg-gold-deep"
    >
      Contact Us
    </a>

    {
      (home.yearBuilt || home.lotSizeAcres) && (
        <dl class="mt-6 space-y-3 border-t border-neutral-800 pt-6">
          {home.yearBuilt && (
            <div class="flex justify-between gap-4 text-sm">
              <dt class="text-neutral-500">Year built</dt>
              <dd class="font-medium text-neutral-200">{home.yearBuilt}</dd>
            </div>
          )}
          {home.lotSizeAcres && (
            <div class="flex justify-between gap-4 text-sm">
              <dt class="text-neutral-500">Lot size</dt>
              <dd class="font-medium text-neutral-200">
                {home.lotSizeAcres} acres
              </dd>
            </div>
          )}
        </dl>
      )
    }

    {
      hasResources && (
        <div class="mt-6 space-y-3 border-t border-neutral-800 pt-6 text-sm">
          <h3 class="font-semibold text-neutral-200">Additional Resources</h3>
          {home.floorplan2DPath && (
            <a
              class="block text-gold hover:text-gold-deep"
              href={home.floorplan2DPath}
              target="_blank"
              rel="noopener noreferrer"
            >
              View 2D floor plan
            </a>
          )}
          {home.floorplan3DPath && (
            <a
              class="block text-gold hover:text-gold-deep"
              href={home.floorplan3DPath}
              target="_blank"
              rel="noopener noreferrer"
            >
              View 3D floor plan
            </a>
          )}
          {home.videoTourUrl && (
            <a
              class="block text-gold hover:text-gold-deep"
              href={home.videoTourUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              Watch video tour
            </a>
          )}
          {home.listingUrl && (
            <a
              class="block text-neutral-400 hover:text-gold"
              href={home.listingUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              View original listing{" "}
              <span class="sr-only">(opens in a new tab)</span>
            </a>
          )}
        </div>
      )
    }
  </div>
</aside>
