---
// src/components/ContactForm.astro

const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;
const isConfigured = Boolean(web3formsKey);

const inputClasses = `
    w-full rounded-xl border border-neutral-800
    bg-brand-darker/70 px-4 py-3
    text-sm text-neutral-100
    placeholder:text-neutral-600
    transition-colors
    focus:border-gold/60 focus:outline-none
    focus:ring-2 focus:ring-gold/10
`;
---

<div
  class="rounded-2xl border border-neutral-800
        bg-brand-darker/60 p-6 shadow-xl sm:p-8"
>
  {
    isConfigured ? (
      <form
        id="contact-form"
        action="https://api.web3forms.com/submit"
        method="POST"
      >
        <input type="hidden" name="access_key" value={web3formsKey} />

        <input
          type="hidden"
          name="subject"
          value="New Quality Homes Website Inquiry"
        />

        <input type="hidden" name="from_name" value="Quality Homes Website" />

        <input
          type="checkbox"
          name="botcheck"
          class="hidden"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
        />

        <div class="grid gap-6 sm:grid-cols-2">
          <div>
            <label
              for="first-name"
              class="mb-2 block text-sm font-semibold
                                text-neutral-200"
            >
              First name
              <span class="text-gold" aria-hidden="true">
                *
              </span>
            </label>

            <input
              id="first-name"
              name="first_name"
              type="text"
              autocomplete="given-name"
              required
              maxlength="100"
              class={inputClasses}
              placeholder="First name"
            />
          </div>

          <div>
            <label
              for="last-name"
              class="mb-2 block text-sm font-semibold
                                text-neutral-200"
            >
              Last name
              <span class="text-gold" aria-hidden="true">
                *
              </span>
            </label>

            <input
              id="last-name"
              name="last_name"
              type="text"
              autocomplete="family-name"
              required
              maxlength="100"
              class={inputClasses}
              placeholder="Last name"
            />
          </div>
        </div>

        <div class="mt-6 grid gap-6 sm:grid-cols-2">
          <div>
            <label
              for="email"
              class="mb-2 block text-sm font-semibold
                                text-neutral-200"
            >
              Email address
              <span class="text-gold" aria-hidden="true">
                *
              </span>
            </label>

            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              inputmode="email"
              required
              maxlength="254"
              class={inputClasses}
              placeholder="you@example.com"
            />
          </div>

          <div>
            <label
              for="phone"
              class="mb-2 block text-sm font-semibold
                                text-neutral-200"
            >
              Phone number
              <span class="font-normal text-neutral-500">(optional)</span>
            </label>

            <input
              id="phone"
              name="phone"
              type="tel"
              autocomplete="tel"
              inputmode="tel"
              maxlength="30"
              class={inputClasses}
              placeholder="(812) 555-0123"
            />
          </div>
        </div>

        <div class="mt-6">
          <label
            for="inquiry-type"
            class="mb-2 block text-sm font-semibold
                            text-neutral-200"
          >
            How can we help?
            <span class="text-gold" aria-hidden="true">
              *
            </span>
          </label>

          <select
            id="inquiry-type"
            name="inquiry_type"
            required
            class={inputClasses}
          >
            <option value="" selected disabled>
              Select an inquiry type
            </option>
            <option value="Buying a home">Buying a home</option>
            <option value="Selling a home">Selling a home</option>
            <option value="Rental inquiry">Rental inquiry</option>
            <option value="Schedule a showing">Schedule a showing</option>
            <option value="General question">General question</option>
          </select>
        </div>

        <div class="mt-6">
          <label
            for="property-address"
            class="mb-2 block text-sm font-semibold
                            text-neutral-200"
          >
            Property address
            <span class="font-normal text-neutral-500">(if applicable)</span>
          </label>

          <input
            id="property-address"
            name="property_address"
            type="text"
            autocomplete="street-address"
            maxlength="200"
            class={inputClasses}
            placeholder="Property you are contacting us about"
          />
        </div>

        <div class="mt-6">
          <label
            for="message"
            class="mb-2 block text-sm font-semibold
                            text-neutral-200"
          >
            Message
            <span class="text-gold" aria-hidden="true">
              *
            </span>
          </label>

          <textarea
            id="message"
            name="message"
            required
            minlength="10"
            maxlength="3000"
            rows="6"
            class={`${inputClasses} resize-y`}
            placeholder="Tell us how we can help..."
          />

          <p class="mt-2 text-xs text-neutral-500">
            Please avoid including sensitive personal or financial information.
          </p>
        </div>

        <div class="mt-8">
          <button
            id="contact-submit"
            type="submit"
            class="w-full rounded-full bg-gold px-6 py-3
                            text-sm font-bold text-brand-darker
                            transition-colors
                            hover:bg-gold-deep
                            focus:outline-none focus:ring-2
                            focus:ring-gold/40 focus:ring-offset-2
                            focus:ring-offset-brand-darker
                            disabled:cursor-not-allowed
                            disabled:opacity-60"
          >
            Send Message
          </button>

          <p
            id="contact-status"
            class="mt-4 hidden rounded-xl border px-4 py-3
                            text-center text-sm"
            role="status"
            aria-live="polite"
            tabindex="-1"
          />
        </div>
      </form>
    ) : (
      <div class="py-10 text-center">
        <h2 class="text-xl font-bold text-neutral-100">
          Contact form temporarily unavailable
        </h2>

        <p class="mt-3 text-sm text-neutral-400">
          Please check back shortly or contact us directly.
        </p>
      </div>
    )
  }
</div>

<script>
  function initializeContactForm() {
    const form = document.querySelector<HTMLFormElement>("#contact-form");

    const submitButton =
      document.querySelector<HTMLButtonElement>("#contact-submit");

    const status = document.querySelector<HTMLElement>("#contact-status");

    if (!form || !submitButton || !status) return;
    if (form.dataset.initialized === "true") return;

    form.dataset.initialized = "true";

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      const originalButtonText = submitButton.textContent;

      submitButton.disabled = true;
      submitButton.textContent = "Sending...";

      status.className =
        "mt-4 rounded-xl border border-neutral-700 " +
        "bg-neutral-900/70 px-4 py-3 text-center " +
        "text-sm text-neutral-300";

      status.textContent = "Sending your message...";

      try {
        const response = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: {
            Accept: "application/json",
          },
        });

        const result = await response.json();

        if (!response.ok || !result.success) {
          throw new Error(result.message || "Your message could not be sent.");
        }

        form.reset();

        status.className =
          "mt-4 rounded-xl border border-emerald-400/30 " +
          "bg-emerald-400/10 px-4 py-3 text-center " +
          "text-sm text-emerald-300";

        status.textContent =
          "Thank you! Your message has been sent successfully.";
      } catch (error) {
        const message =
          error instanceof Error
            ? error.message
            : "Something went wrong. Please try again.";

        status.className =
          "mt-4 rounded-xl border border-red-400/30 " +
          "bg-red-400/10 px-4 py-3 text-center " +
          "text-sm text-red-300";

        status.textContent = message;
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = originalButtonText || "Send Message";

        status.focus();
      }
    });
  }

  initializeContactForm();

  document.addEventListener("astro:page-load", initializeContactForm);
</script>
